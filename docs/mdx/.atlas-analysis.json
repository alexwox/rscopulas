  "keyFeatures": [
    "Up to ~100× faster than R's copula/VineCopula stack on vine log_pdf workloads",
    "NumPy-first Python API backed by a Rust core via PyO3/maturin",
    "Single-family copulas: Gaussian, Student t, Clayton, Frank, Gumbel",
    "Vine copulas: C-vine, D-vine, and R-vine with mixed pair-family fitting",
    "Khoudraji asymmetric pair copulas for flexible skewed dependence",
    "Hierarchical Archimedean copulas (HAC) with nested structure",
    "Fit diagnostics: log-likelihood, AIC, BIC, convergence, iteration count",
    "Optional visualization via rscopulas.plotting (matplotlib, viz extra)",
    "Strict pseudo-observation validation — rejects boundary and non-finite values",
    "Reference-tested against R packages copula and VineCopula"
  ],
  "publicApiSurface": [
    "GaussianCopula.fit(data)",
