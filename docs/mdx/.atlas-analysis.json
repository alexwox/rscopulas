    "VineCopula.fit_c(data, family_set, criterion, truncation_level)",
    "VineCopula.fit_d(data, family_set, criterion, truncation_level)",
    "VineCopula.gaussian_c_vine(order, correlation)",
    "VineCopula.gaussian_d_vine(order, correlation)",
    "VineCopula.from_trees(kind, trees)",
    "PairCopula.from_spec(family, parameters, rotation)",
